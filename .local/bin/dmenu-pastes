#!/usr/bin/env bash
# vim:ft=bash:tw=79:sw=2:ts=2:sts=2:et
#------------------------------------------------------------------------------
# Author: 00riddle00 (Tomas Giedraitis)
# Date:   2024-09-27 13:13:58 EEST
# Path:   ~/.local/bin/dmenu-pastes
# URL:    https://github.com/00riddle00/dotfiles
#------------------------------------------------------------------------------
#*
# Choose some text to paste from a list and copy it to the clipboard.
#**

#* USAGE:
#*   ${0}
#**

set -euo pipefail

PASTES_FILE="${DOTSHARE}/misc/pastes.tsv"
TEMP_FILE="$(mktemp)"

xclip -h &>/dev/null || exit 1
touch "$PASTES_FILE"

# Show only the text column, sorted by frequency descending
choice=$(sort -t$'\t' -k2,2nr "$PASTES_FILE" | cut -f1 | dmenu -i -l 20)

[[ -z "$choice" ]] && exit 1

# Update frequency
awk -F'\t' -v txt="$choice" -v OFS='\t' '
  $1 == txt { $2 += 1; found=1 }
  { print }
  END { if (!found) print txt, 1 }
' "$PASTES_FILE" > "$TEMP_FILE"

mv "$TEMP_FILE" "$PASTES_FILE"

# Copy to clipboard
echo -n "$choice" | xclip -selection clipboard
notify-send "$choice copied to clipboard."
